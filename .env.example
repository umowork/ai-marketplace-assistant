# Configuration
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321
DATABASE_URL=sqlite+aiosqlite:///bot.db
REDIS_URL=redis://localhost:6379/0

# LLM (OpenAI / GigaChat)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai          # openai | gigachat

# Marketplace API keys (опционально, для Seller API)
WB_API_KEY=
OZON_CLIENT_ID=
OZON_API_KEY=

# Flags
MOCK_MODE=true               # true = мок-данные, false = реальные API
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
